---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import SocialPill from '../components/SocialPill.astro';
import emailIcon from '../components/icons/email.svg?raw';
import GitHubIcon from '../components/icons/github.svg?raw';
---

<Layout>
    <main>
    <section id="inicio" class="mx-auto flex w-full max-w-6xl flex-col gap-10 px-6 pt-16 pb-20">
            <div class="reveal-up delay-1 flex flex-wrap items-center gap-4">
                <Badge>Disponible para trabajar</Badge>
                <span class="text-xs uppercase tracking-[0.3em] text-white/40">Portafolio 2026</span>
            </div>

            <div class="max-w-3xl">
                <h1 class="reveal-up delay-2 text-balance text-4xl font-semibold text-white sm:text-5xl lg:text-6xl">
                    Hey, soy
                    <span class="animated-name bg-gradient-to-r from-yellow-200 via-amber-300 to-orange-400 bg-clip-text text-transparent">
                        Jose Luis
                    </span>
                </h1>
                <p class="reveal-up delay-3 mt-6 text-lg text-white/70 sm:text-xl">
                    Estudiante de desarrollo de software apasionado por la tecnologia y el desarrollo web.
                    Experiencia en proyectos personales y colaborativos.
                    Busco oportunidades para aplicar mis habilidades y crecer profesionalmente en el campo del desarrollo de software.
                </p>
            </div>

            <nav class="reveal-up delay-4 flex flex-wrap gap-4">
                <SocialPill
                    href="mailto:jose.luism.dev@gmail.com"
                    label="Email"
                    icon={emailIcon}
                />
                <SocialPill
                    href="https://www.github.com/Joseeee0909"
                    label="GitHub"
                    icon={GitHubIcon}
                />
            </nav>
        </section>

        <section id="experiencia" class="mx-auto w-full max-w-6xl px-6 pb-16">
            <div class="reveal-up delay-1 card p-8">
                <h2 class="text-2xl font-semibold text-white">Experiencia</h2>
                <p class="mt-4 text-white/70">
                    Experiencia en varios proyectos colaborativos, aunque sin experiencia real en empresas.
                </p>
                <div class="mt-6 grid gap-4 text-sm text-white/60 sm:grid-cols-2">
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Trabajo en equipo y coordinacion remota.</div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Flujos con Git y revisiones de codigo.</div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Prototipos rapidos y validacion con usuarios.</div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Deploy en entornos cloud y ajustes post-lanzamiento.</div>
                </div>
            </div>
        </section>

        <section id="habilidades" class="mx-auto w-full max-w-6xl px-6 pb-16">
            <div class="flex items-center justify-between gap-4">
                <h2 class="text-2xl font-semibold text-white">Habilidades</h2>
                <span class="text-xs uppercase tracking-[0.3em] text-white/40">Stack actual</span>
            </div>
            <div class="mt-8 grid gap-6 md:grid-cols-3">
                <article class="reveal-up delay-1 card p-6">
                    <h3 class="text-lg font-semibold text-white">Frontend</h3>
                    <p class="mt-3 text-sm text-white/70">Interfaces modernas, animaciones y UX enfocada en conversion.</p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="tag">React</span>
                        <span class="tag">Next.js</span>
                        <span class="tag">Vite</span>
                    </div>
                </article>
                <article class="reveal-up delay-2 card p-6">
                    <h3 class="text-lg font-semibold text-white">Backend</h3>
                    <p class="mt-3 text-sm text-white/70">APIs en tiempo real, seguridad basica y modelos escalables.</p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="tag">Node.js</span>
                        <span class="tag">Express</span>
                        <span class="tag">Firebase</span>
                    </div>
                </article>
                <article class="reveal-up delay-3 card p-6">
                    <h3 class="text-lg font-semibold text-white">Datos</h3>
                    <p class="mt-3 text-sm text-white/70">Persistencia y consultas con foco en performance.</p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="tag">MongoDB</span>
                        <span class="tag">PostgreSQL</span>
                        <span class="tag">ORM</span>
                    </div>
                </article>
            </div>
        </section>

        <section id="proyectos" class="mx-auto w-full max-w-6xl px-6 pb-20">
            <div class="flex items-center justify-between gap-4">
                <h2 class="text-2xl font-semibold text-white">Proyectos</h2>
                <span class="text-xs uppercase tracking-[0.3em] text-white/40">En crecimiento</span>
            </div>
            <div class="mt-8 grid gap-6 md:grid-cols-2">
                <article class="reveal-up delay-1 card p-6">
                    <h3 class="text-lg font-semibold text-white">Tenpos</h3>
                    <p class="mt-3 text-sm text-white/70">
                        Sistema POS en tiempo real para toma de pedidos desde dispositivos moviles y division directa a cocina y caja.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="tag">Node.js</span>
                        <span class="tag">Express</span>
                        <span class="tag">MongoDB Atlas</span>
                        <span class="tag">React</span>
                        <span class="tag">Next.js</span>
                        <span class="tag">Vite</span>
                    </div>
                </article>
                <article class="reveal-up delay-2 card p-6">
                    <h3 class="text-lg font-semibold text-white">Gestor de tareas</h3>
                    <p class="mt-3 text-sm text-white/70">
                        Gestor de tareas desplegado en Vercel y Render con stack full web.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="tag">Django</span>
                        <span class="tag">React</span>
                        <span class="tag">Vercel</span>
                        <span class="tag">Render</span>
                    </div>
                </article>
                <article class="reveal-up delay-3 card p-6">
                    <h3 class="text-lg font-semibold text-white">Chat tipo Discord</h3>
                    <p class="mt-3 text-sm text-white/70">
                        Sistema de chat inspirado en Discord con autenticacion y tiempo real.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="tag">Firebase</span>
                        <span class="tag">React</span>
                        <span class="tag">Realtime</span>
                    </div>
                </article>
                <article class="reveal-up delay-4 card p-6">
                    <h3 class="text-lg font-semibold text-white">Mas proyectos pronto</h3>
                    <p class="mt-3 text-sm text-white/70">
                        Estoy construyendo nuevas ideas y pronto habra mas lanzamientos.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="tag">En progreso</span>
                    </div>
                </article>
            </div>
        </section>

        <section id="sobre-mi" class="mx-auto w-full max-w-6xl px-6 pb-16">
            <div class="reveal-up delay-1 card p-8">
                <h2 class="text-2xl font-semibold text-white">Sobre mi</h2>
                <p class="mt-4 text-white/70">
                    Estudiante apasionado con ansias de seguir creciendo y generando experiencia.
                </p>
            </div>
        </section>

        <section id="contacto" class="mx-auto w-full max-w-6xl px-6 pb-24">
            <div class="reveal-up delay-1">
                <h2 class="text-3xl font-semibold text-white">Hablemos.</h2>
                <p class="mt-3 max-w-2xl text-white/70">
                    Estoy disponible para proyectos freelance, colaboraciones y oportunidades remotas.
                    Si tienes una idea en mente o quieres trabajar juntos, escribeme.
                </p>
            </div>
            <div class="contact-grid mt-10">
                <div class="flex flex-col gap-4">
                    <a class="contact-link" href="https://www.github.com/Joseeee0909" target="_blank" rel="noreferrer">
                        <span>GitHub</span>
                        <span aria-hidden="true">↗</span>
                    </a>
                    <a class="contact-link" href="#" target="_blank" rel="noreferrer">
                        <span>LinkedIn</span>
                        <span aria-hidden="true">↗</span>
                    </a>
                    <a class="contact-link" href="mailto:jose.luim.dev@gmail.com">
                        <span>Email</span>
                        <span aria-hidden="true">↗</span>
                    </a>
                    <div class="contact-card">
                        <p class="text-sm text-white/60">Respondo en menos de 24 horas</p>
                        <div class="mt-3 flex flex-wrap gap-3">
                            <SocialPill
                                href="mailto:jose.luim.dev@gmail.com"
                                label="Email"
                                icon={emailIcon}
                            />
                            <SocialPill
                                href="https://www.github.com/Joseeee0909"
                                label="GitHub"
                                icon={GitHubIcon}
                            />
                        </div>
                    </div>
                </div>
                <form class="contact-form" autocomplete="off">
                    <label class="contact-field">
                        <span>Nombre</span>
                        <input class="contact-input" type="text" name="name" placeholder="Tu nombre" />
                    </label>
                    <label class="contact-field">
                        <span>Email</span>
                        <input class="contact-input" type="email" name="email" placeholder="tu@email.com" />
                    </label>
                    <label class="contact-field">
                        <span>Mensaje</span>
                        <textarea class="contact-input" name="message" rows="5" placeholder="Cuentame tu proyecto o propuesta..."></textarea>
                    </label>
                    <button class="contact-button" type="button">Enviar por WhatsApp</button>
                </form>
            </div>
        </section>
    </main>
        

</Layout>
